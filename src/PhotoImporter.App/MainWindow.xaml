<Window x:Class="PhotoImporter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photo Importer" Height="680" Width="1080"
        MinHeight="520" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="写真の取り込みプレビュー"
                   FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="コピー元" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0" ToolTip="写真があるフォルダー" />
            <Button Grid.Column="2" Content="選択..." Click="SelectSource_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="コピー先" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0" ToolTip="取り込み先フォルダー" />
            <Button Grid.Column="2" Content="選択..." Click="SelectDestination_Click" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="テンプレート" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding TemplateText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0"
                     ToolTip="例: {ModifiedDate:yyyy-MM-dd}\{FileName}{Sequence}{Extension}" />
            <Button Grid.Column="2" Content="スキャン" MinWidth="100"
                    IsDefault="True" IsEnabled="{Binding CanScan}" Click="Scan_Click" />
        </Grid>

        <DataGrid Grid.Row="4" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" EnableRowVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="コピー元" Binding="{Binding SourcePath}" Width="2*" />
                <DataGridTextColumn Header="コピー先（予定）" Binding="{Binding DestinationPath}" Width="3*" />
                <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Message}" Foreground="{Binding MessageBrush}"
                       VerticalAlignment="Center" TextWrapping="Wrap" />
            <TextBlock Grid.Column="1" Text="{Binding Summary}" Margin="18,0,0,0"
                       VerticalAlignment="Center" FontWeight="SemiBold" />
        </Grid>
    </Grid>
</Window>
