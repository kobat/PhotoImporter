<Window x:Class="PhotoImporter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photo Importer" Height="820" Width="1480"
        MinHeight="680" MinWidth="1180"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CopyTargetCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="IsEnabled" Value="{Binding CanCopy}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <DataTemplate x:Key="TokenDetailTemplate">
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="0,0,0,1" Padding="0,7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="TokenNameColumn" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Token}" FontFamily="Consolas" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Value, Mode=OneWay}"
                               Margin="12,0,8,0" VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <ToggleButton Grid.Column="2" Width="24" Height="24" Padding="0"
                                  FontSize="10" IsChecked="{Binding IsFormatEditorVisible, Mode=TwoWay}"
                                  AutomationProperties.Name="トークン詳細の表示切り替え"
                                  ToolTip="トークンの説明と書式設定の表示を切り替えます">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="▼" />
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="▲" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,7,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFormatEditorVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBox Text="{Binding Format, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="書式設定" Padding="4,2" Margin="0,0,0,7">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SupportsFormat}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBlock Text="{Binding Description}" Foreground="DimGray"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding FormatDescription}" Margin="0,7,0,0"
                                   Foreground="DimGray" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SupportsFormat}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="650" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="460" MinWidth="380" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="写真の取り込みプレビュー"
                   FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18" />

        <Grid Grid.Row="1" Margin="0,0,0,10" IsEnabled="{Binding CanEditSettings}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="コピー元" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0" ToolTip="写真があるフォルダー" />
            <Button Grid.Column="2" Content="選択..." Click="SelectSource_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10" IsEnabled="{Binding CanEditSettings}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="コピー先" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0" ToolTip="取り込み先のフォルダー" />
            <Button Grid.Column="2" Content="選択..." Click="SelectDestination_Click" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="テンプレート" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding TemplateText, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding CanEditSettings}" Margin="0,0,8,0"
                     ToolTip="例: {ModifiedDate:yyyy-MM-dd}\{FileName}{Sequence}{Extension}" />
            <Button Grid.Column="2" Content="スキャン" MinWidth="100"
                    IsDefault="True" IsEnabled="{Binding CanScan}" Click="Scan_Click" />
        </Grid>

        <Grid Grid.Row="4" Margin="112,0,0,10" IsEnabled="{Binding CanEditSettings}">
            <StackPanel>
                <CheckBox Content="RAW+JPEGペアではJPEGのみ解析する"
                          IsChecked="{Binding AnalyzeJpegOnlyForRawJpegPair}" />
                <TextBlock Text="同じフォルダーにある同名のRAWとJPEGをペアとして扱います。ペアにならないRAWは個別に解析します"
                           Margin="20,2,0,0" Foreground="DimGray" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Expander Grid.Row="5" Header="Exif キャッシュ設定" Margin="0,0,0,10"
                  IsEnabled="{Binding CanEditSettings}">
            <StackPanel Margin="112,8,0,2">
                <CheckBox Content="テンプレートで未使用の場合もExif情報を読み込む"
                          IsChecked="{Binding ReadExifInformation}" Margin="0,0,0,8" />
                <CheckBox Content="Exif キャッシュを利用する"
                          IsChecked="{Binding UseExifCache}" />
                <Grid Margin="20,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding ExifCacheRoot, Mode=OneWay}" IsReadOnly="True"
                             Margin="0,0,8,0" ToolTip="現在使用する Exif キャッシュの保存先" />
                    <Button Grid.Column="1" Content="保存先を変更..." Margin="0,0,8,0"
                            Click="SelectExifCacheRoot_Click" />
                    <Button Grid.Column="2" Content="既定に戻す"
                            Click="ResetExifCacheRoot_Click" />
                </Grid>
                <TextBlock Text="保存先を変えても、以前の保存先にあるキャッシュは移動・削除されません。"
                           Margin="20,4,0,0" Foreground="DimGray" TextWrapping="Wrap" />
            </StackPanel>
        </Expander>

        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="コピー設定" VerticalAlignment="Center" />
            <CheckBox Grid.Column="1" Content="既存ファイルを上書きする"
                      IsEnabled="{Binding CanEditSettings}" IsChecked="{Binding OverwriteExisting}" />
            <Button Grid.Column="2" Content="{Binding CopyButtonText}" MinWidth="100" Margin="8,0,0,0"
                    IsEnabled="{Binding CanCopy}" Click="Copy_Click" />
            <Button Grid.Column="3" Content="キャンセル" MinWidth="100" Margin="8,0,0,0"
                    IsEnabled="{Binding CanCancel}" Click="Cancel_Click" />
        </Grid>

        <Grid Grid.Row="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ViewSelectionSummary}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Column="1"
                          Content="絞り込みで非表示になった項目のチェックを外す"
                          IsChecked="{Binding UncheckHiddenItems, Mode=TwoWay}"
                          IsEnabled="{Binding CanSelectItems}"
                          VerticalAlignment="Center" />
            </Grid>
        <DataGrid Grid.Row="1" ItemsSource="{Binding ItemsView}"
                  SelectedItem="{Binding SelectedPreviewItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" EnableRowVirtualization="True"
                  IsEnabled="{Binding CanSelectItems}">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        ElementStyle="{StaticResource CopyTargetCheckBoxStyle}"
                                        EditingElementStyle="{StaticResource CopyTargetCheckBoxStyle}"
                                        Width="80">
                    <DataGridCheckBoxColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsThreeState="True"
                                      IsChecked="{Binding DataContext.SelectAllState, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Mode=OneWay}"
                                      IsEnabled="{Binding DataContext.CanSelectAll, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                      Click="SelectAll_Click"
                                      Margin="0,0,6,0"
                                      VerticalAlignment="Center"
                                      AutomationProperties.Name="コピー可能な項目をすべて選択または解除"
                                      ToolTip="コピー可能な項目をすべて選択／解除" />
                            <TextBlock Text="対象" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="コピー元" Binding="{Binding SourcePath}" Width="2*" IsReadOnly="True" />
                <DataGridTextColumn Header="コピー先（予定）" Binding="{Binding DestinationPath}" Width="3*" IsReadOnly="True" />
                <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="180" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
        </Grid>

        <GridSplitter Grid.Row="1" Grid.RowSpan="7" Grid.Column="1"
                      Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="Transparent" ResizeDirection="Columns" />

        <Border Grid.Row="1" Grid.RowSpan="7" Grid.Column="2" Margin="14,0,0,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1" CornerRadius="4" Padding="12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="トークン詳細" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedSourcePath}" Margin="0,4,0,0"
                               TextWrapping="Wrap" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ExifReadStatus}" Margin="0,3,0,0"
                               TextWrapping="Wrap" Foreground="DimGray" />
                    <TextBlock Text="書式欄を変更すると、その書式で値を再評価します。"
                               Margin="0,5,0,0" TextWrapping="Wrap" Foreground="DimGray" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Grid.IsSharedSizeScope="True">
                        <GroupBox Header="ファイルシステム系" Margin="0,0,0,12">
                            <ItemsControl ItemsSource="{Binding FileSystemTokenDetails}"
                                          ItemTemplate="{StaticResource TokenDetailTemplate}" Margin="10,4" />
                        </GroupBox>
                        <GroupBox Header="Exif系">
                            <ItemsControl ItemsSource="{Binding ExifTokenDetails}"
                                          ItemTemplate="{StaticResource TokenDetailTemplate}" Margin="10,4" />
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="8" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"
                         Visibility="{Binding ProgressVisibility}" />
            <TextBlock Grid.Column="1" Text="{Binding ProgressText}" Margin="12,0,0,0"
                       VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="9" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Message}" Foreground="{Binding MessageBrush}"
                       VerticalAlignment="Center" TextWrapping="Wrap" />
            <TextBlock Grid.Column="1" Text="{Binding Summary}" Margin="18,0,0,0"
                       VerticalAlignment="Center" FontWeight="SemiBold" />
        </Grid>
    </Grid>
</Window>
